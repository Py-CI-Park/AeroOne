{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aeroone.internal/schemas/internal-data-trust.schema.json",
  "title": "AeroOne Internal Data Bundle Trust Policy",
  "description": "Deployed to C:\\ProgramData\\AeroOne\\trust\\internal-data-trust.json (owner Administrators, inheritance disabled, exactly 3 read-only ACEs: SYSTEM, Administrators, authorized operator SID). Its SHA-256 digest MUST be pinned at HKLM:\\SOFTWARE\\AeroOne\\InternalData\\TrustPolicySha256; an absent or mismatched pin is a FAIL.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "expires_at",
    "max_approval_ttl_hours",
    "allowed_roots",
    "signers",
    "recipients"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "policy_id": { "type": "string", "minLength": 1 },
    "expires_at": { "type": "string", "format": "date-time" },
    "max_approval_ttl_hours": { "type": "integer", "minimum": 1, "maximum": 24 },
    "allowed_roots": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["newsletter", "civil_aircraft", "document", "nsa"]
      }
    },
    "signers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "thumbprint", "subject", "eku_oid"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["data_owner", "nsa_data_owner", "security_officer"]
          },
          "thumbprint": { "type": "string", "pattern": "^[0-9A-F]{40}$" },
          "subject": { "type": "string", "minLength": 1 },
          "eku_oid": { "type": "string", "const": "1.3.6.1.4.1.311.10.3.12" }
        }
      }
    },
    "recipients": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target_environment_id", "thumbprint", "subject", "eku_oid"],
        "properties": {
          "target_environment_id": { "type": "string", "minLength": 1 },
          "thumbprint": { "type": "string", "pattern": "^[0-9A-F]{40}$" },
          "subject": { "type": "string", "minLength": 1 },
          "eku_oid": { "type": "string", "const": "1.3.6.1.5.5.7.3.4" }
        }
      }
    }
  }
}
