APP_ENV=development
APP_NAME=AeroOne Newsletter Platform
BACKEND_PORT=8000
FRONTEND_PORT=3000
DATABASE_URL=sqlite:///./backend/data/aeroone.db
JWT_SECRET_KEY=change-me
ADMIN_SESSION_COOKIE_NAME=admin_session
